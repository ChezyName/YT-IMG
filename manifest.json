{
    "name": "YT Images",
    "description": "Allows the viewing of images in YouTube comments.",
    "version": "1.0",
    "manifest_version": 3,
    "content_scripts": [
        {
            "js": [
                "logger.js", "context.js", "settings.js", "image.js", "comments.js", "image_upload.js", "main.js"
            ],
            "matches": [
            "*://*.youtube.com/*"
            ]
        }
    ],
    "permissions": [ "storage", "clipboardRead", "activeTab" ],
    "action": {
        "default_title": "Open Settings",
        "default_popup": "popup.html"
    },
    "host_permissions": [ "https://catbox.moe/*" ],
    "background": {
        "service_worker": "background.js"
    }
}