{
  "name": "Images for YouTube",
  "description": "Allows the viewing of images in YouTube comments.",
  "version": "1.1.0",
  "manifest_version": 3,
  "content_scripts": [
    {
      "js": [
        "logger.js",
        "context.js",
        "settings.js",
        "image.js",
        "comments.js",
        "image_upload.js",
        "main.js"
      ],
      "matches": [
        "*://*.youtube.com/*"
      ]
    }
  ],
  "permissions": [
    "storage",
    "clipboardRead",
    "activeTab"
  ],
  "action": {
    "default_title": "Open Settings",
    "default_popup": "popup.html"
  },
  "host_permissions": [
    "https://catbox.moe/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon_16.png",
    "32": "icons/icon_32.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  }
}